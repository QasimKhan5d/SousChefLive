{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SousChef Harness Report",
  "description": "Structured artifact schema for harness run reports",
  "type": "object",
  "required": ["run_id", "tier", "passed", "events", "summary"],
  "properties": {
    "run_id": { "type": "string" },
    "tier": { "type": "string", "enum": ["static", "unit", "integration", "system", "live", "deploy"] },
    "scenario_id": { "type": "string" },
    "passed": { "type": "boolean" },
    "duration_ms": { "type": "number" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "component", "event_type"],
        "properties": {
          "timestamp": { "type": "string" },
          "run_id": { "type": "string" },
          "session_id": { "type": "string" },
          "component": { "type": "string" },
          "event_type": { "type": "string" },
          "severity": { "type": "string" },
          "latency_ms": { "type": "number" },
          "details": { "type": "object" }
        }
      }
    },
    "summary": { "type": "string" },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    }
  }
}
